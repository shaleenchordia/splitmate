# Copy to backend/.env — settings.py loads it automatically in local dev.
# Google AI Studio key: https://aistudio.google.com/apikey
# Without it, every AI feature still works via the offline fallbacks
# (except receipt scanning, which is disabled).
GEMINI_API_KEY=
