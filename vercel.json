{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb" }
    },
    { "src": "backend/staticfiles/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/admin/(.*)", "dest": "/api/index.py" },
    { "src": "/assets/(.*)", "dest": "/backend/staticfiles/assets/$1" },
    { "src": "/(.*)", "dest": "/backend/staticfiles/index.html" }
  ]
}
